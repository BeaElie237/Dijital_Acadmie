# --- Variables FRONTEND (exposées au navigateur, préfixe VITE_ obligatoire) ---
# À définir en local dans un fichier .env, et dans Netlify (Site settings > Environment variables)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Variables SERVEUR (Netlify Functions uniquement, jamais exposées au frontend) ---
# À définir UNIQUEMENT dans Netlify (Site settings > Environment variables), pas de préfixe VITE_
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Clé API Resend (https://resend.com) — utilisée pour envoyer l'email d'accès
# à chaque création d'étudiant. Créer un compte gratuit, puis Dashboard > API Keys.
RESEND_API_KEY=re_xxxxxxxxxxxx
# Optionnel : expéditeur personnalisé, nécessite un domaine vérifié sur Resend.
# Sans domaine vérifié, laisser cette ligne commentée (utilise onboarding@resend.dev).
# RESEND_FROM_EMAIL=Dijital <no-reply@dijital.com>

# --- Utilisé uniquement par scripts/seed.mjs en local (fichier .env.seed, jamais commité) ---
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
